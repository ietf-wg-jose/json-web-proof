{
  "name": "jwp-fixtures",
  "version": "0.0.1",
  "description": "",
  "main": "fixtureize.js",
  "engines": {
    "node": ">=22.13.1"
  },
  "scripts": {
    "pretest": "make fixtures",
    "test": "cd fixtures && jasmine --config=spec/support/jasmine.mjs --random=true --seed=1337",
    "test:random": "cd fixtures && jasmine --config=spec/support/jasmine.mjs --random=true",
    "check:repro:fixtures": "node --no-warnings scripts/check-repro.mjs --mode=fixtures",
    "check:repro": "node --no-warnings scripts/check-repro.mjs --mode=full",
    "check:fixtures:artifacts": "node --no-warnings scripts/check-fixture-artifacts.mjs",
    "check:fixtures:docs": "node --no-warnings scripts/check-fixture-docs.mjs",
    "update:fixtures:manifest": "node --no-warnings scripts/update-fixture-manifest.mjs",
    "update:fixtures:doc-manifest": "node --no-warnings scripts/update-fixture-doc-manifest.mjs",
    "update:fixtures:manifests": "npm run update:fixtures:manifest && npm run update:fixtures:doc-manifest",
    "lint:fixtures": "node --no-warnings scripts/lint-fixtures.mjs",
    "verify": "make fixtures && npm run check:fixtures:artifacts && npm run check:fixtures:docs && npm run lint:fixtures && npm test && npm run test:random && npm run check:repro:fixtures && make"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@alksol/cfrg-bbs": "file:./fixtures/vendor/alksol-cfrg-bbs-0.1.0.tgz",
    "cbor-edn": "^0.2.2",
    "cbor2": "^2.0.1",
    "jose": "^6"
  },
  "devDependencies": {
    "jasmine": "^6.1"
  }
}
